{
    "name": "openclaw-guide",
    "version": "1.0.0",
    "description": "OpenClaw 从入门到精通",
    "scripts": {
        "init": "mdpress init",
        "build": "rm -rf _site _site_site && mdpress build --format site --output _site && rm -rf _site && mv _site_site _site",
        "serve": "mdpress serve",
        "start": "mdpress serve",
        "clean": "rimraf _book _site",
        "pdf": "mdpress build --format pdf"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/yeasy/openclaw_guide.git"
    },
    "author": "yeasy",
    "license": "CC-BY-4.0",
    "bugs": {
        "url": "https://github.com/yeasy/openclaw_guide/issues"
    },
    "homepage": "https://github.com/yeasy/openclaw_guide#readme",
    "devDependencies": {
        "gitbook-plugin-mermaid-gb3": "^2.1.0",
        "rimraf": "^6.1.3"
    },
    "dependencies": {
        "playwright": "^1.58.2"
    }
}
